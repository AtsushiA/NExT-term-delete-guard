{
  "name": "next-term-delete-guard",
  "version": "1.0.0",
  "description": "カテゴリー、タグ、タクソノミーに紐づく記事がある場合、削除を防止するWordPressプラグイン",
  "private": true,
  "scripts": {
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:destroy": "wp-env destroy",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.php": "composer run phpcs --"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@wordpress/env": "^11.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
